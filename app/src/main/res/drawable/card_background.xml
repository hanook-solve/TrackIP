<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow layer 3 (widest, most transparent) -->
    <item
        android:left="-4dp"
        android:top="-4dp"
        android:right="-4dp"
        android:bottom="-4dp">
        <shape>
            <solid android:color="#00000000"/>
            <stroke android:width="4dp" android:color="#337B7FFF"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Outer glow layer 2 -->
    <item
        android:left="-2dp"
        android:top="-2dp"
        android:right="-2dp"
        android:bottom="-2dp">
        <shape>
            <solid android:color="#00000000"/>
            <stroke android:width="3dp" android:color="#667B7FFF"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <!-- Outer glow layer 1 (closest, most visible) -->
    <item>
        <shape>
            <solid android:color="#00000000"/>
            <stroke android:width="2dp" android:color="#997B7FFF"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- Main card background -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="#12163A"/>
            <stroke android:width="1dp" android:color="#7B7FFF"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

</layer-list>
